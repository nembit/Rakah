# Rakah — Environment Variables
# Copy this file to .env and fill in values for your environment.
# The .env file is gitignored and should never be committed.

# API base URL used by the mock backend server.
# For Android emulator, use 10.0.2.2 to reach your machine's localhost.
# For physical device testing, use your machine's LAN IP (e.g. http://192.168.1.x:4000/api).
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000/api

# Google Maps API key (only required if map features are enabled)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
